# ── Required ──────────────────────────────────────────────────────────────
MONGODB_URI=                      # MongoDB connection string
MONGODB_DB=interview_bot          # database name
JWT_SECRET=                       # strong random secret (app won't start without it)

# At least ONE LLM provider (Groq recommended). They form a fallback chain.
GROQ_API_KEY=
MISTRAL_API=
CEREBRAS_API=

# ── Optional: agent tools ─────────────────────────────────────────────────
TAVILY_API_KEY=                   # enables the web_search tool
GITHUB_TOKEN=                     # github_profile: unlocks streak + 5000/hr rate limit

# ── Optional: password-reset email (Gmail → use an App Password) ───────────
SMTP_HOST=                        # e.g. smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=

# ── Optional: tuning (sensible defaults if omitted) ───────────────────────
FRONTEND_URL=http://localhost:3000     # base URL used in reset links
CORS_ORIGINS=                          # comma-separated; defaults to localhost:3000/5173
JWT_EXPIRE_DAYS=30
RESET_TOKEN_TTL_MIN=30
# GROQ_MODEL=llama-3.3-70b-versatile
# MISTRAL_MODEL=mistral-large-latest
# CEREBRAS_MODEL=gpt-oss-120b
# AUTH_DEV_LOG_RESET_LINK=true         # DEV ONLY: print reset link to stdout when no SMTP
